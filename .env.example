# ======================================================================
# Copy to .env and fill in real values.
# Production refuses to start with missing/insecure SECRET_KEY.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(64))"
# ======================================================================

# Django Settings
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=False
DJANGO_SETTINGS_MODULE=project.settings.production
ENVIRONMENT=production
# Public domain(s) only — internal hostnames (backend, localhost) are
# appended automatically for container healthchecks and server-side calls.
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database Configuration
POSTGRES_DB=blood_donation_db
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password

# CORS Configuration (comma-separated list)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# API docs (Swagger/ReDoc). Disable on hardened production deployments.
API_DOCS_ENABLED=False

# JWT lifetimes
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Throttling (DRF rates)
THROTTLE_ANON=1000/hour
THROTTLE_USER=10000/hour
THROTTLE_LOGIN=10/min
THROTTLE_REGISTER=20/hour
THROTTLE_OTP=5/min

# Password-reset OTP flow
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_VERIFY_ATTEMPTS=5
RESET_TOKEN_TTL_SECONDS=600
# NEVER set to True in production — echoes the OTP in the API response
# (dev-only convenience until an SMS gateway is wired up in users/services.py)
OTP_DEBUG_EXPOSE=False

# Sentry Error Monitoring (optional)
SENTRY_DSN=

# Email Configuration (optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=noreply@blooddonation.com
ADMIN_EMAIL=admin@blooddonation.com

# HTTPS redirect (production). Set False when TLS is terminated upstream
# of nginx or the deployment is HTTP-only on an internal network.
SECURE_SSL_REDIRECT=True

# Frontend (Next.js) — browser API calls are same-origin through nginx
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=your-nextauth-secret

# Optional: auto-create the initial admin account on container start
# (safe to leave set — creation is skipped once the account exists)
#DJANGO_SUPERUSER_MOBILE_NUMBER=01XXXXXXXXX
#DJANGO_SUPERUSER_PASSWORD=change-me-Strong@123

# Reported by /health/status/
APP_VERSION=1.0.0

# Timezone
TZ=Asia/Dhaka
